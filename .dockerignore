# This file is based on .gitignore and adds Docker-specific ignores.

# From .gitignore
node_modules
.husky/_
**.log
# local env files
.env
.test.env

# Log files
dist/
.vscode/
test-path-resolution.js

# SonarLint Connected Mode config
.sonarlint/connectedMode.json

# E2E Testing Logs
test/logs

# Docker-specific ignores

# Ignore all test files
**/*.spec.ts

# Ignore Dockerfiles themselves
Dockerfile
Dockerfile.prod

# Ignore git history
.git
.gitignore

# Ignore markdown files not needed in the image
README.md
CONTRIBUTING.md
GEMINI.md
docs/**/*.md

# Ignore configuration files not needed in the final image
.prettierrc
.prettierignore
.test.env.example
.env.example
.env.prod
Caddyfile
eslint.config.js
# nest-cli.json # Needed for build
sonar-project.properties
# tsconfig.build.json # Needed for build
# tsconfig.json # Needed for build

# Allow essential config files for the build
!tsconfig.json
!tsconfig.build.json
!nest-cli.json