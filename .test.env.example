# Test environment variables
# This file contains environment variables for E2E testing
# Other environment variables are set up by the E2E test utils

# Gemini API Key - will be populated from GitHub secrets in CI
GEMINI_API_KEY=YOUR_GEMINI_API_KEY_HERE

# Mistral API Key - will be populated from GitHub secrets in CI
MISTRAL_API_KEY=YOUR_MISTRAL_API_KEY_HERE

# DEFAULT_TEXT_TABLE_MODEL: Model used for text/table assessment tasks (defaults to mistral-small-latest)
DEFAULT_TEXT_TABLE_MODEL=mistral-small-latest

# DEFAULT_IMAGE_MODEL: Model used for image assessment tasks (defaults to mistral-small-latest)
DEFAULT_IMAGE_MODEL=mistral-small-latest

# TEXT_REASONING_EFFORT: Abstract reasoning effort for text/table tasks (defaults to low)
TEXT_REASONING_EFFORT=low

# IMAGE_REASONING_EFFORT: Abstract reasoning effort for image tasks (defaults to high)
IMAGE_REASONING_EFFORT=high