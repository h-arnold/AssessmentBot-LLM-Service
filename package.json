{
  "name": "assessmentbot-llm-service",
  "version": "0.1.12",
  "type": "module",
  "description": "The backend for Assessment Bot, which provides LLM services.",
  "author": "Hamish Arnold",
  "private": true,
  "license": "ISC",
  "engines": {
    "node": ">=22.13.0"
  },
  "scripts": {
    "build": "nest build",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
    "start": "nest start",
    "start:dev": "nest start --watch",
    "start:debug": "nest start --debug --watch",
    "debug": "node --inspect-brk ./node_modules/.bin/nest start",
    "start:prod": "NODE_ENV=production node dist/src/main.js",
    "dev:delegate": "NODE_OPTIONS=--experimental-specifier-resolution=node ts-node --esm scripts/codex-delegate.ts",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "lint:british": "./scripts/check-british-english.sh",
    "test": "vitest run --project unit",
    "test:watch": "vitest --project unit",
    "test:cov": "vitest run --coverage --project unit",
    "test:debug": "node --inspect-brk node_modules/.bin/vitest run --project unit --pool=forks --poolOptions.forks.singleFork",
    "test:e2e": "npm run test:e2e:mocked",
    "test:e2e:mocked": "npm run build && vitest run --project e2e",
    "test:e2e:live": "npm run build && vitest run --project e2e-live",
    "test:prod": "npm run build && vitest run --project prod",
    "prepare": "husky"
  },
  "dependencies": {
    "@google/genai": "^2.10.0",
    "@google/generative-ai": "^0.24.1",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@nestjs/common": "^11.1.19",
    "@nestjs/config": "^4.0.4",
    "@nestjs/core": "^11.1.19",
    "@nestjs/passport": "^11.0.5",
    "@nestjs/platform-express": "^11.1.19",
    "@nestjs/swagger": "^11.3.0",
    "@nestjs/throttler": "^6.5.0",
    "@openai/codex-sdk": "^0.142.5",
    "dotenv": "^17.4.2",
    "file-type": "^22.0.1",
    "jsonrepair": "^3.14.0",
    "mime-detect": "^1.3.0",
    "mustache": "^4.2.0",
    "nestjs-pino": "^4.6.1",
    "passport": "^0.7.0",
    "passport-http-bearer": "^1.0.1",
    "pino-http": "^11.0.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2",
    "validator": "^13.15.35",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@nestjs/cli": "^11.0.21",
    "@nestjs/schematics": "^11.1.0",
    "@nestjs/testing": "^11.1.19",
    "@stylistic/eslint-plugin": "^5.10.0",
    "@types/express": "^5.0.6",
    "@types/mustache": "^4.2.6",
    "@types/node": "^26.0.1",
    "@types/passport": "^1.0.17",
    "@types/passport-http-bearer": "^1.0.42",
    "@types/supertest": "^7.2.0",
    "@types/validator": "^13.15.10",
    "@typescript-eslint/eslint-plugin": "^8.58.2",
    "@typescript-eslint/parser": "^8.58.2",
    "@vitest/coverage-v8": "^4.1.10",
    "axios": "^1.15.0",
    "eslint": "^10.2.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-import-x": "^4.16.2",
    "eslint-plugin-jsdoc": "^63.0.11",
    "eslint-plugin-n": "^18.2.1",
    "eslint-plugin-no-secrets": "^2.3.3",
    "eslint-plugin-prettier": "^5.5.5",
    "eslint-plugin-regexp": "^3.1.0",
    "eslint-plugin-security": "^4.0.0",
    "eslint-plugin-sonarjs": "^4.0.3",
    "eslint-plugin-unicorn": "^69.0.0",
    "globals": "^17.5.0",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.8",
    "pino-pretty": "^13.1.3",
    "prettier": "^3.8.3",
    "supertest": "^7.2.2",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.58.2",
    "vitest": "^4.1.10"
  },
  "overrides": {
    "micromatch": ">=4.0.8",
    "test-exclude": "7.0.1",
    "lodash": "4.18.1",
    "@angular-devkit/core": {
      "ajv": "8.18.0"
    },
    "@nestjs/schematics": {
      "ajv": "8.18.0"
    }
  },
  "homepage": "https://github.com/h-arnold/AssessmentBot-LLM-Service#readme",
  "lint-staged": {
    "*.ts": "eslint --fix",
    "*.{js,ts,json,md}": "prettier --write",
    "*.{ts,js}": "./scripts/check-british-english.sh"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/h-arnold/AssessmentBot-LLM-Service.git"
  },
  "bugs": {
    "url": "https://github.com/h-arnold/AssessmentBot-LLM-Service/issues"
  }
}
